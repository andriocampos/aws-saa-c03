# =============================================================================
# EXEMPLO DE VARIÁVEIS — copie para terraform.tfvars e ajuste os valores
# =============================================================================
# Como usar:
#   cp terraform.tfvars.example terraform.tfvars
#   Edite terraform.tfvars com seus valores
#   terraform.tfvars NÃO é commitado no git (está no .gitignore)
# =============================================================================

aws_region          = "us-east-1"
project_name        = "lab01"
vpc_cidr            = "10.0.0.0/16"
public_subnet_cidr  = "10.0.1.0/24"
private_subnet_cidr = "10.0.2.0/24"

# Recomendado: troque "0.0.0.0/0" pelo seu IP público + /32
# Para descobrir seu IP: curl ifconfig.me
allowed_ssh_cidr = "0.0.0.0/0"
